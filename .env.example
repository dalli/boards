# Example NON-SECRET config for local dev (deployment.md).
# Copy to .env.dev for local use. NEVER commit real secrets; prod injects at runtime (§4).

# Postgres
POSTGRES_USER=boards
POSTGRES_PASSWORD=boards
POSTGRES_DB=boards

# Backend / DB
DATABASE_URL=postgresql+psycopg://boards:boards@localhost:5432/boards

# Auth (dev placeholder — rotate in real envs)
JWT_SECRET=dev-insecure-change-me

# MinIO / S3 (dev placeholder credentials)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_ATTACHMENTS=attachments
S3_BUCKET_THUMBNAILS=thumbnails

# Initial admin seed (password injected via env at runtime, never committed)
SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=<inject-at-runtime>

# Frontend
VITE_API_BASE_URL=http://localhost:8000
